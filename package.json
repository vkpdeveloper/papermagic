{
    "name": "papermagic",
    "private": true,
    "version": "1.0.4",
    "description": "Offline-first desktop reader for PDFs, EPUBs, and saved web pages.",
    "author": "Vaibhav",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "start": "tsc --noEmit && vite build --mode production && electron . --no-sandbox",
        "build:icons": "mkdir -p build/icon && electron-icon-builder --input papermagic_logo.png --output build/icon --flatten",
        "build": "npm run build:icons && tsc && vite build && electron-builder",
        "build:linux": "npm run build:icons && tsc && vite build && electron-builder --linux",
        "build:mac": "npm run build:icons && tsc && vite build && electron-builder --mac --arm64",
        "build:win": "npm run build:icons && tsc && vite build && electron-builder --win",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "postinstall": "electron-builder install-app-deps"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@fontsource/poppins": "^5.2.7",
        "@hyzyla/pdfium": "^2.1.12",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@streamdown/cjk": "^1.0.3",
        "@streamdown/code": "^1.1.1",
        "@streamdown/math": "^1.0.2",
        "@streamdown/mermaid": "^1.0.2",
        "@tanstack/react-hotkeys": "^0.4.1",
        "better-sqlite3": "^12.8.0",
        "drizzle-orm": "^0.45.1",
        "fast-xml-parser": "^5.5.6",
        "jszip": "^3.10.1",
        "linkedom": "^0.18.12",
        "lucide-react": "^0.577.0",
        "mupdf": "^1.27.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sonner": "^2.0.7",
        "streamdown": "^2.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.5.0",
        "@types/react": "^18.2.64",
        "@types/react-dom": "^18.2.21",
        "@typescript-eslint/eslint-plugin": "^7.1.1",
        "@typescript-eslint/parser": "^7.1.1",
        "@vitejs/plugin-react": "^4.2.1",
        "electron": "^30.0.1",
        "electron-builder": "^26.8.1",
        "electron-icon-builder": "^2.0.1",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "png-to-icns": "^1.0.0",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.2.2",
        "vite": "^5.1.6",
        "vite-plugin-electron": "^0.28.6",
        "vite-plugin-electron-renderer": "^0.14.5"
    },
    "main": "dist-electron/main.js",
    "optionalDependencies": {
        "@rollup/rollup-darwin-arm64": "^4.59.0"
    }
}
